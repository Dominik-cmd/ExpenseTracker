# Copy this file to .env and fill in real values before running docker compose
# .env is gitignored - never commit it

# Database password - use something strong
POSTGRES_PASSWORD=change-me-strong-password

# JWT signing secret - minimum 32 chars, random
# Generate with: openssl rand -base64 48
JWT_SECRET=change-me-minimum-32-chars-random-secret-here

# Password for the single app user (dominik) - change after first login
INITIAL_PASSWORD=ChangeMeNow!

# Set to Production for server, Development only for local dev (enables DB auto-create)
ASPNETCORE_ENVIRONMENT=Production

# The URL your browser uses to reach the frontend - used for CORS
# If running on a local server accessible by IP: http://192.168.1.x:4200
FRONTEND_ORIGIN=http://localhost:4200
