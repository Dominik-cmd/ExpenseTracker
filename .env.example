# Copy this file to .env and fill in real values before running docker compose
# .env is gitignored - never commit it

# Database password - use something strong
POSTGRES_PASSWORD=change-me-strong-password

# JWT signing secret - minimum 32 chars, random
# Generate with: openssl rand -base64 48
JWT_SECRET=change-me-minimum-32-chars-random-secret-here

# Username for the initial admin user (default: admin)
# INITIAL_USERNAME=admin

# Password for the initial admin user - change after first login via the UI
INITIAL_PASSWORD=ChangeMeNow!

# Set to Production for server, Development only for local dev (enables DB auto-create)
ASPNETCORE_ENVIRONMENT=Production

# Your public frontend URL - used for CORS. Must match what your browser uses.
# Examples:
#   FRONTEND_ORIGIN=https://expenses.yourdomain.com
#   FRONTEND_ORIGIN=http://localhost:4200
FRONTEND_ORIGIN=http://localhost:4200

# Optional: customize port bindings (default: 127.0.0.1:8082 for API, 127.0.0.1:4200 for frontend)
# API_PORT=127.0.0.1:8082
# FRONTEND_PORT=127.0.0.1:4200
