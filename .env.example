# Copy this file to .env and fill in real values before running docker compose
# .env is gitignored - never commit it

# Database password - use something strong
POSTGRES_PASSWORD=change-me-strong-password

# JWT signing secret - minimum 32 chars, random
# Generate with: openssl rand -base64 48
JWT_SECRET=change-me-minimum-32-chars-random-secret-here

# Password for the single app user (dominik) - change after first login via the UI
INITIAL_PASSWORD=ChangeMeNow!

# Set to Production for server, Development only for local dev (enables DB auto-create)
ASPNETCORE_ENVIRONMENT=Production

# Your public frontend URL - used for CORS. Must match what your browser uses.
# With nginx + domain:
FRONTEND_ORIGIN=https://expenses.iadore.space
